{
  "name": "@yutra/builder",
  "version": "0.1.0-rc.1",
  "private": false,
  "description": "Yutra Basic Agent Builder UI prototype",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @yutra/builder-ai-core build && vite",
    "build": "pnpm --filter @yutra/builder-ai-core build && vite build",
    "preview": "vite preview",
    "test": "pnpm --filter @yutra/builder-ai-core build && vitest run --passWithNoTests",
    "lint": "eslint src test vite.config.ts --max-warnings=0"
  },
  "dependencies": {
    "@yutra/builder-ai-core": "workspace:*",
    "@yutra/builder-core": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.1.0",
    "vite": "^5.4.14"
  },
  "license": "MIT",
  "author": "Yutra Contributors",
  "keywords": ["yutra", "builder", "react", "vite"],
  "main": "dist/index.html",
  "module": "dist/index.html",
  "exports": {
    ".": "./dist/index.html"
  },
  "files": ["dist"]
}
