{
  "name": "@yutra/builder-runner",
  "version": "0.3.0-vnext-preview.1",
  "private": false,
  "description": "Local runner for Yutra Builder run-preview and trace demo",
  "type": "module",
  "main": "dist/server.js",
  "module": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "pnpm --filter @yutra/builder-ai-core build && pnpm --filter @yutra/rule-compiler build && tsup src/server.ts --format esm --dts",
    "test": "pnpm --filter @yutra/builder-ai-core build && pnpm --filter @yutra/rule-compiler build && vitest run --passWithNoTests",
    "lint": "eslint src test --max-warnings=0"
  },
  "dependencies": {
    "@yutra/archetype-core": "workspace:*",
    "@yutra/builder-ai-core": "workspace:*",
    "@yutra/builder-core": "workspace:*",
    "@yutra/dsl": "workspace:*",
    "@yutra/pack-config-core": "workspace:*",
    "@yutra/rule-compiler": "workspace:*",
    "@yutra/runtime": "workspace:*",
    "@yutra/scenario-composition-compiler": "workspace:*",
    "@yutra/scenario-composition-core": "workspace:*",
    "@yutra/scenario-pattern-core": "workspace:*",
    "@yutra/trace": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.20.6"
  },
  "license": "MIT",
  "author": "Yutra Contributors",
  "keywords": ["yutra", "builder", "runner", "trace"]
}
