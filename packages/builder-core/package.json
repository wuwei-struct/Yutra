{
  "name": "@yutra/builder-core",
  "version": "0.3.0-vnext-preview.1",
  "private": false,
  "description": "Yutra builder core: template/form to AgentSpec and Chinese DSL draft",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src test --max-warnings=0"
  },
  "dependencies": {
    "@yutra/spec": "workspace:*",
    "zod": "^3.24.2"
  },
  "license": "MIT",
  "author": "Yutra Contributors",
  "keywords": [
    "yutra",
    "builder",
    "dsl",
    "agentspec"
  ]
}
