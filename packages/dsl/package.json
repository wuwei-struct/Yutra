{
    "name":  "@yutra/dsl",
    "version":  "0.1.0-rc.1",
    "private":  false,
    "description":  "Yutra DSL loader/parser/validator",
    "type":  "module",
    "main":  "dist/index.js",
    "module":  "dist/index.js",
    "types":  "dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js"
                          }
                },
    "files":  [
                  "dist"
              ],
    "scripts":  {
                    "build":  "tsup src/index.ts --format esm --dts",
                    "test":  "vitest run --passWithNoTests",
                    "lint":  "eslint src test --max-warnings=0"
                },
    "dependencies":  {
                         "@yutra/spec":  "workspace:*",
                         "yaml":  "^2.8.1"
                     },
    "license":  "MIT",
    "author":  "Yutra Contributors",
    "keywords":  [
                     "yutra",
                     "dsl",
                     "yaml",
                     "json",
                     "validator"
                 ]
}
