{
    "name":  "@yutra/spec",
    "version":  "0.1.0-rc.1",
    "private":  false,
    "description":  "Yutra execution standard v0.1",
    "type":  "module",
    "main":  "dist/index.js",
    "module":  "dist/index.js",
    "types":  "dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js"
                          }
                },
    "files":  [
                  "dist"
              ],
    "scripts":  {
                    "build":  "tsup src/index.ts --format esm --dts",
                    "test":  "vitest run --passWithNoTests",
                    "lint":  "eslint src test --max-warnings=0"
                },
    "dependencies":  {
                         "zod":  "^3.24.2"
                     },
    "license":  "MIT",
    "author":  "Yutra Contributors",
    "keywords":  [
                     "yutra",
                     "spec",
                     "schema",
                     "zod",
                     "agent-execution"
                 ]
}
