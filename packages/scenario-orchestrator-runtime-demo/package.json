{
  "name": "@yutra/scenario-orchestrator-runtime-demo",
  "version": "0.3.0-vnext-preview.1",
  "private": false,
  "description": "Deterministic mock-only in-memory Scenario Slot Runtime Adapter",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run --passWithNoTests",
    "smoke": "vitest run scripts/smoke.test.ts --reporter=verbose",
    "smoke:alignment": "vitest run scripts/alignment-smoke.test.ts --reporter=verbose",
    "lint": "eslint src scripts test --max-warnings=0"
  },
  "dependencies": {
    "@yutra/dsl": "workspace:*",
    "@yutra/runtime": "workspace:*",
    "@yutra/scenario-orchestrator-core": "workspace:*",
    "@yutra/scenario-orchestrator-runtime-contract": "workspace:*"
  },
  "devDependencies": {
    "@yutra/scenario-composition-core": "workspace:*",
    "@yutra/scenario-orchestrator-compiler": "workspace:*"
  },
  "license": "MIT",
  "author": "Yutra Contributors",
  "keywords": [
    "yutra",
    "scenario-orchestrator",
    "runtime-adapter",
    "in-memory",
    "demo"
  ]
}
