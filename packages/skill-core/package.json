{
  "name": "@yutra/skill-core",
  "version": "0.3.0-vnext-preview.1",
  "private": false,
  "description": "Yutra skill manifest schema, loader, and validator",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "license": "MIT",
  "author": "Yutra Contributors",
  "keywords": [
    "yutra",
    "skill",
    "manifest",
    "loader"
  ]
}
