# E-commerce support integration mode
YUTRA_ECOM_ADAPTER_MODE=mock
YUTRA_ECOM_ENVIRONMENT=demo
YUTRA_ECOM_ADAPTER_DRY_RUN=true

# Shared upstream endpoint and auth placeholders
YUTRA_ECOM_API_BASE_URL=https://api.example.local
YUTRA_ECOM_AUTH_TOKEN=replace_with_token
YUTRA_ECOM_API_KEY=replace_with_api_key

# Optional adapter-specific endpoint overrides
YUTRA_ECOM_ORDER_API_BASE_URL=https://order.example.local
YUTRA_ECOM_SHIPPING_API_BASE_URL=https://shipping.example.local
YUTRA_ECOM_RETURN_API_BASE_URL=https://return.example.local
YUTRA_ECOM_REFUND_API_BASE_URL=https://refund.example.local
YUTRA_ECOM_ESCALATION_API_BASE_URL=https://escalation.example.local
YUTRA_ECOM_CHANNEL_API_BASE_URL=https://channel.example.local

# Runtime alignment with adapter skeleton
YUTRA_ECOM_TIMEOUT_MS=5000
YUTRA_ECOM_RETRY_MAX_ATTEMPTS=2
YUTRA_ECOM_RETRY_BACKOFF_MS=200
